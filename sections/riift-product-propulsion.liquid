{% liquid
  assign current_product = product
  if section.settings.product != blank
    assign current_product = section.settings.product
  endif

  assign propulsion_stats = current_product.metafields.riift.propulsion_stats.value
  assign propulsion_image = current_product.metafields.riift.propulsion_image.value
%}

{% if propulsion_stats != blank %}
  <div class="riift-page riift-product-propulsion-section" data-section-id="{{ section.id }}">
    <section class="riift-product-propulsion" data-reveal>
      {% if propulsion_image != blank %}
        {{
          propulsion_image
          | image_url: width: 2400
          | image_tag: class: 'riift-product-propulsion__image', loading: 'lazy', alt: ''
        }}
      {% else %}
        <div class="riift-product-propulsion__placeholder"></div>
      {% endif %}
      <div class="riift-product-propulsion__scrim"></div>

      <div class="riift-product-propulsion__content">
        {% capture propulsion_eyebrow %}
          {% render 'riift-product-mf', product: current_product, key: 'propulsion_eyebrow' %}
        {% endcapture %}
        {% if propulsion_eyebrow != blank %}
          <p class="riift-eyebrow riift-product-propulsion__eyebrow" data-reveal>{{ propulsion_eyebrow | strip }}</p>
        {% endif %}

        {% capture propulsion_heading %}
          {% render 'riift-product-mf', product: current_product, key: 'propulsion_heading' %}
        {% endcapture %}
        {% if propulsion_heading != blank %}
          <h2 class="riift-h2 riift-product-propulsion__heading" data-reveal>{{ propulsion_heading | strip }}</h2>
        {% endif %}

        <div class="riift-product-propulsion__stats">
          {% for stat in propulsion_stats %}
            <div class="riift-product-propulsion__stat" data-reveal>
              <p class="riift-product-propulsion__stat-value">
                {{ stat.value -}}
                {%- if stat.unit != blank -%}
                  <span class="riift-product-propulsion__stat-unit">{{ stat.unit }}</span>
                {%- endif %}
              </p>
              {% if stat.label != blank %}
                <p class="riift-body riift-product-propulsion__stat-label">{{ stat.label }}</p>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </section>
  </div>
{% endif %}

{% schema %}
{
  "name": "RIIFT Product propulsion",
  "class": "riift-product-propulsion-section",
  "tag": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Propulsion band from product metafields riift.propulsion_* in Admin."
    }
  ],
  "presets": [
    {
      "name": "RIIFT Product propulsion"
    }
  ]
}
{% endschema %}

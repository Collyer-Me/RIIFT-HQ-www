{% liquid
  assign color_scheme = section.settings.color_scheme | default: 'auto'

  if color_scheme == 'auto'
    if template.name == 'product'
      assign color_scheme = 'on_light'
    else
      assign color_scheme = 'on_dark'
    endif
  endif

  assign header_classes = 'riift-header riift-header--' | append: color_scheme

  if color_scheme == 'on_light' or section.settings.transparent_mode == false
    assign header_classes = header_classes | append: ' is-scrolled'
  endif
%}

<header
  class="{{ header_classes }}"
  data-section-id="{{ section.id }}"
  data-header-scheme="{{ color_scheme }}"
  data-scroll-nav="{% if color_scheme == 'on_dark' and section.settings.transparent_mode %}true{% else %}false{% endif %}"
>
  <a href="{{ routes.root_url }}" class="riift-header__logo">
    {% if color_scheme == 'on_light' %}
      {% if section.settings.logo_on_light != blank %}
        {{
          section.settings.logo_on_light
          | image_url: width: 200
          | image_tag: alt: shop.name, loading: 'eager'
        }}
      {% else %}
        <img
          src="{{ 'riift-logo-black.png' | asset_url }}"
          alt="{{ shop.name }}"
          width="80"
          height="24"
          loading="eager"
        >
      {% endif %}
    {% elsif section.settings.logo != blank %}
      {{
        section.settings.logo
        | image_url: width: 200
        | image_tag: alt: shop.name, loading: 'eager'
      }}
    {% else %}
      <img
        src="{{ 'riift-logo-white.png' | asset_url }}"
        alt="{{ shop.name }}"
        width="80"
        height="24"
        loading="eager"
      >
    {% endif %}
  </a>

  <nav class="riift-header__nav" aria-label="Main">
    {% for block in section.blocks %}
      {% if block.type == 'link' %}
        <a
          href="{{ block.settings.url }}"
          class="riift-header__link{% if block.settings.active %} is-active{% endif %}"
          {{ block.shopify_attributes }}
        >
          {{ block.settings.label }}
        </a>
      {% endif %}
    {% endfor %}
    {% if section.settings.show_search %}
      <a href="{{ routes.search_url }}" class="riift-header__search" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="21" y1="21" x2="16.5" y2="16.5"></line>
        </svg>
      </a>
    {% endif %}
  </nav>

  <button type="button" class="riift-header__menu-toggle" data-riift-menu-toggle aria-label="Menu" aria-expanded="false">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <line x1="4" y1="7" x2="20" y2="7"></line>
      <line x1="4" y1="12" x2="20" y2="12"></line>
      <line x1="4" y1="17" x2="20" y2="17"></line>
    </svg>
  </button>
</header>

{% unless section.settings.transparent_mode and template.name == 'index' and color_scheme == 'on_dark' %}
  <div class="riift-header-spacer" aria-hidden="true"></div>
{% endunless %}

{% stylesheet %}
  @media (max-width: 899px) {
    .riift-header__nav.is-open {
      display: flex;
      flex-direction: column;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      padding: 20px var(--riift-page-gutter) 28px;
    }

    .riift-header--on_dark .riift-header__nav.is-open {
      background: var(--riift-nav-bg-scrolled);
      border-bottom: 1px solid var(--riift-nav-border-scrolled);
    }

    .riift-header--on_light .riift-header__nav.is-open {
      background: var(--riift-header-bg-light);
      border-bottom: 1px solid var(--riift-header-border-light);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "RIIFT Header",
  "class": "riift-header-section",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Navigation colors",
      "info": "Auto uses black nav on product pages and white nav elsewhere.",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "on_dark", "label": "White — over photos and dark backgrounds" },
        { "value": "on_light", "label": "Black — over white and light backgrounds" }
      ],
      "default": "auto"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo (white on dark)",
      "info": "Used with white navigation over photos and dark backgrounds."
    },
    {
      "type": "image_picker",
      "id": "logo_on_light",
      "label": "Logo (black on light)",
      "info": "Used with black navigation over white and light backgrounds. Defaults to theme black wordmark."
    },
    {
      "type": "checkbox",
      "id": "transparent_mode",
      "label": "Transparent until scroll",
      "info": "White nav only. Black nav always shows a solid light bar.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search icon",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Nav link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Link"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        },
        {
          "type": "checkbox",
          "id": "active",
          "label": "Active state",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RIIFT Header",
      "blocks": [
        { "type": "link", "settings": { "label": "Boards", "url": "/pages/boards" } },
        { "type": "link", "settings": { "label": "System", "url": "/pages/system" } },
        { "type": "link", "settings": { "label": "Shapers", "url": "/pages/shapers" } },
        { "type": "link", "settings": { "label": "Dealers", "url": "/pages/dealers" } },
        { "type": "link", "settings": { "label": "People", "url": "/pages/people" } },
        { "type": "link", "settings": { "label": "Contact", "url": "/pages/contact" } }
      ]
    }
  ]
}
{% endschema %}

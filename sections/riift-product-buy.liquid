{% liquid
  assign current_product = product
  if section.settings.product != blank
    assign current_product = section.settings.product
  endif

  assign default_tier = section.settings.default_tier | default: '4P' | upcase
  assign variants_sorted = current_product.variants | sort: 'option1'
  assign selected_variant = current_product.selected_or_first_available_variant

  for variant in variants_sorted
    assign variant_tier = variant.option1 | default: variant.title | strip | upcase
    if variant_tier == default_tier
      assign selected_variant = variant
    endif
  endfor

  assign hero_image = selected_variant.featured_image | default: current_product.featured_image | default: section.settings.fallback_image
  assign wizard_url = section.settings.wizard_url | default: '/pages/wizard'
%}

<div class="riift-page riift-product-buy-section" data-section-id="{{ section.id }}">
  <div
    class="riift-product-buy"
    data-riift-product-buy
    data-default-tier="{{ default_tier }}"
  >
    <script type="application/json" data-riift-product-data>
      [{% for variant in variants_sorted %}{% render 'riift-powerpack-variant-json', variant: variant %}{% unless forloop.last %},{% endunless %}{% endfor %}]
    </script>

    <div class="riift-product-buy__grid">
      <div class="riift-product-buy__gallery">
        <div class="riift-product-buy__hero">
          {% if hero_image != blank %}
            {{
              hero_image
              | image_url: width: 1600
              | image_tag:
                class: 'riift-product-buy__hero-image',
                loading: 'eager',
                alt: current_product.title,
                data-product-hero-image: ''
            }}
          {% else %}
            <div class="riift-product-buy__hero-placeholder" data-product-hero-image></div>
          {% endif %}
          {% if section.settings.gallery_label != blank %}
            <span class="riift-product-buy__gallery-label">{{ section.settings.gallery_label }}</span>
          {% endif %}
        </div>

        {% if current_product.media.size > 1 %}
          <div class="riift-product-buy__thumbs" role="list" aria-label="Product gallery">
            {% for media in current_product.media limit: 4 %}
              <button
                type="button"
                class="riift-product-buy__thumb{% if forloop.first %} is-active{% endif %}"
                data-thumb-index="{{ forloop.index0 }}"
                data-media-id="{{ media.id }}"
                aria-label="{{ media.alt | default: current_product.title | escape }}"
                role="listitem"
              >
                {% if media.media_type == 'image' %}
                  {{
                    media
                    | image_url: width: 200
                    | image_tag: loading: 'lazy', alt: media.alt | default: current_product.title
                  }}
                {% else %}
                  <span class="riift-product-buy__thumb-label">{{ media.alt | default: 'Media' }}</span>
                {% endif %}
              </button>
            {% endfor %}
          </div>
        {% elsif section.settings.thumb_labels != blank %}
          <div class="riift-product-buy__thumbs riift-product-buy__thumbs--placeholders" role="list" aria-hidden="true">
            {% assign thumb_labels = section.settings.thumb_labels | split: '|' %}
            {% for label in thumb_labels limit: 4 %}
              <div class="riift-product-buy__thumb riift-product-buy__thumb--placeholder" role="listitem">
                <span class="riift-product-buy__thumb-label">{{ label | strip }}</span>
              </div>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="riift-product-buy__info">
        {% if section.settings.eyebrow != blank %}
          <p class="riift-eyebrow riift-product-buy__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}

        <h1 class="riift-h1 riift-product-buy__title">{{ section.settings.title | default: current_product.title }}</h1>

        {% if section.settings.description != blank %}
          <p class="riift-body riift-product-buy__description">{{ section.settings.description }}</p>
        {% elsif current_product.description != blank %}
          <div class="riift-body riift-product-buy__description">{{ current_product.description }}</div>
        {% endif %}

        {% if variants_sorted.size > 1 %}
          <p class="riift-product-buy__tier-label">{{ section.settings.tier_heading }}</p>
          <div class="riift-product-buy__tiers" role="group" aria-label="{{ section.settings.tier_heading }}">
            {% for variant in variants_sorted %}
              {% liquid
                assign tier_code = variant.option1 | default: variant.title | strip | upcase
                capture tier_label
                  render 'riift-powerpack-spec-value', variant: variant, key: 'tier_label'
                endcapture
                assign is_selected = false
                if variant.id == selected_variant.id
                  assign is_selected = true
                endif
              %}
              <button
                type="button"
                class="riift-product-buy__tier{% if is_selected %} is-selected{% endif %}"
                data-tier-button
                data-variant-id="{{ variant.id }}"
                data-tier="{{ tier_code }}"
                aria-pressed="{% if is_selected %}true{% else %}false{% endif %}"
              >
                <span class="riift-product-buy__tier-name">{{ tier_code }}</span>
                <span class="riift-product-buy__tier-sub">{{ tier_label | strip }}</span>
              </button>
            {% endfor %}
          </div>
        {% endif %}

        <div class="riift-product-buy__price-row">
          <span class="riift-product-buy__price" data-product-price>{{ selected_variant.price | money }}</span>
          <span class="riift-product-buy__price-note">{{ section.settings.price_note }}</span>
        </div>

        <div class="riift-product-buy__key-specs">
          <div class="riift-product-buy__key-spec">
            <p class="riift-product-buy__key-value" data-product-energy>
              {% render 'riift-powerpack-spec-value', variant: selected_variant, key: 'usable_energy' %}
            </p>
            <p class="riift-product-buy__key-label">Usable energy</p>
          </div>
          <div class="riift-product-buy__key-spec">
            <p class="riift-product-buy__key-value" data-product-run>
              {% render 'riift-powerpack-spec-value', variant: selected_variant, key: 'efoil_run_time' %}
            </p>
            <p class="riift-product-buy__key-label">Efoil run time*</p>
          </div>
          <div class="riift-product-buy__key-spec">
            <p class="riift-product-buy__key-value" data-product-weight>
              {% render 'riift-powerpack-spec-value', variant: selected_variant, key: 'pack_weight' %}
            </p>
            <p class="riift-product-buy__key-label">Pack weight</p>
          </div>
        </div>

        <p class="riift-body riift-product-buy__compat" data-product-compat>
          {% render 'riift-powerpack-spec-value', variant: selected_variant, key: 'track_compat_line' %}
        </p>

        <form
          class="riift-product-buy__form"
          action="{{ routes.cart_add_url }}"
          method="post"
          data-product-form
        >
          <input type="hidden" name="id" value="{{ selected_variant.id }}" data-variant-input>
          <input type="hidden" name="quantity" value="1">

          <div class="riift-product-buy__actions">
            <button
              type="submit"
              class="riift-btn riift-btn--solid riift-btn--solid-pill"
              data-add-to-cart
              {% unless selected_variant.available %}disabled{% endunless %}
            >
              {% if selected_variant.available %}
                {{ section.settings.buy_label }}
              {% else %}
                {{ 'products.product.sold_out' | t }}
              {% endif %}
            </button>
            {% render 'riift-button',
              variant: 'ghost',
              label: section.settings.wizard_label,
              url: wizard_url,
              class: 'riift-btn--outline-dark'
            %}
          </div>
          <p class="riift-caption riift-product-buy__footnote" data-product-error hidden></p>
        </form>

        {% if section.settings.footnote != blank %}
          <p class="riift-caption riift-product-buy__footnote">{{ section.settings.footnote }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<script src="{{ 'riift-product.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "RIIFT Product buy block",
  "class": "riift-product-buy-section",
  "tag": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Leave blank to use the current product page."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "RIIFT Power System"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title override",
      "info": "Leave blank to use the product title."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description override",
      "default": "Battery, onboard computer and propulsion in one balanced, tool-less, clip-in kit. Choose your range — every pack shares the same pod, remote and case."
    },
    {
      "type": "text",
      "id": "tier_heading",
      "label": "Tier selector label",
      "default": "Choose your pack"
    },
    {
      "type": "select",
      "id": "default_tier",
      "label": "Default tier",
      "options": [
        { "value": "2P", "label": "2P" },
        { "value": "3P", "label": "3P" },
        { "value": "4P", "label": "4P" }
      ],
      "default": "4P"
    },
    {
      "type": "text",
      "id": "price_note",
      "label": "Price note",
      "default": "AUD incl. GST"
    },
    {
      "type": "text",
      "id": "buy_label",
      "label": "Buy button label",
      "default": "Buy now"
    },
    {
      "type": "text",
      "id": "wizard_label",
      "label": "Wizard button label",
      "default": "Help me choose"
    },
    {
      "type": "url",
      "id": "wizard_url",
      "label": "Wizard URL"
    },
    {
      "type": "text",
      "id": "footnote",
      "label": "Footnote",
      "default": "Launches September 2026 · PowerPack delivery from December 2026."
    },
    {
      "type": "text",
      "id": "gallery_label",
      "label": "Gallery overlay label",
      "default": "RIIFT Power System"
    },
    {
      "type": "text",
      "id": "thumb_labels",
      "label": "Placeholder thumb labels",
      "default": "PowerPack|Propulsion Unit|Remote|Hard Case",
      "info": "Shown when the product has only one image. Pipe-separated."
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "Fallback hero image"
    }
  ],
  "presets": [
    {
      "name": "RIIFT Product buy block"
    }
  ]
}
{% endschema %}

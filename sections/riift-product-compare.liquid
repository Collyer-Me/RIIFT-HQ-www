{% liquid
  assign current_product = product
  if section.settings.product != blank
    assign current_product = section.settings.product
  endif

  assign show_comparison = current_product.metafields.riift.show_comparison.value
  assign compare_rows = current_product.metafields.riift.compare_rows.value
%}

{% if show_comparison != false and compare_rows != blank %}
  <div class="riift-page riift-product-compare-section" data-section-id="{{ section.id }}">
    <section class="riift-product-compare">
      <div class="riift-product-compare__intro" data-reveal>
        {% capture compare_heading %}
          {% render 'riift-product-mf', product: current_product, key: 'compare_heading' %}
        {% endcapture %}
        {% if compare_heading != blank %}
          <h2 class="riift-h2">{{ compare_heading | strip }}</h2>
        {% endif %}

        {% capture compare_intro %}
          {% render 'riift-product-mf', product: current_product, key: 'compare_intro' %}
        {% endcapture %}
        {% if compare_intro != blank %}
          <p class="riift-body">{{ compare_intro | strip }}</p>
        {% endif %}
      </div>

      <div class="riift-product-compare__table" data-reveal>
        <div class="riift-product-compare__row riift-product-compare__row--head">
          <span class="riift-product-compare__label"></span>
          {% capture column_1 %}
            {% render 'riift-product-mf', product: current_product, key: 'compare_column_1_label' %}
          {% endcapture %}
          {% capture column_2 %}
            {% render 'riift-product-mf', product: current_product, key: 'compare_column_2_label' %}
          {% endcapture %}
          <span class="riift-product-compare__value riift-product-compare__value--primary">{{ column_1 | strip }}</span>
          <span class="riift-product-compare__value riift-product-compare__value--muted">{{ column_2 | strip }}</span>
        </div>

        {% for row in compare_rows %}
          <div class="riift-product-compare__row">
            <span class="riift-product-compare__label">{{ row.label }}</span>
            <span class="riift-product-compare__value riift-product-compare__value--primary">{{ row.riift_value }}</span>
            <span class="riift-product-compare__value riift-product-compare__value--muted">{{ row.compare_value }}</span>
          </div>
        {% endfor %}
      </div>
    </section>
  </div>
{% endif %}

{% schema %}
{
  "name": "RIIFT Product comparison",
  "class": "riift-product-compare-section",
  "tag": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Comparison table from product metafields riift.compare_* in Admin."
    }
  ],
  "presets": [
    {
      "name": "RIIFT Product comparison"
    }
  ]
}
{% endschema %}

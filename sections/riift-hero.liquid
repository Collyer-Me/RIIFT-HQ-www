{% liquid
  assign slide_count = 0
  for block in section.blocks
    if block.type == 'slide'
      assign slide_count = slide_count | plus: 1
    endif
  endfor

  assign height_mode = section.settings.height | default: 'viewport'
%}

<div
  class="riift-full-bleed"
  data-riift-hero
  data-height="{{ height_mode }}"
  data-slide-interval="{{ section.settings.slide_interval | times: 1000 }}"
  data-section-id="{{ section.id }}"
>
  <div class="riift-hero__slides">
    {% if slide_count == 0 %}
      <div class="riift-hero__slide is-active" style="background: linear-gradient(135deg, #1a1a1a 0%, #0d0d0d 50%, #2a3a4a 100%);"></div>
    {% else %}
      {% assign slide_index = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'slide' %}
          <div
            class="riift-hero__slide{% if slide_index == 0 %} is-active{% endif %}"
            {% if block.settings.image != blank %}
              style="background-image: url('{{ block.settings.image | image_url: width: 2400 }}');"
            {% else %}
              style="background: linear-gradient(135deg, #1a1a1a 0%, #0d0d0d 50%, #2a3a4a 100%);"
            {% endif %}
            {{ block.shopify_attributes }}
          ></div>
          {% assign slide_index = slide_index | plus: 1 %}
        {% endif %}
      {% endfor %}
    {% endif %}
  </div>

  <div class="riift-hero__scrim"></div>

  <div class="riift-hero__content{% if section.settings.alignment == 'center' %} riift-hero__content--center{% endif %}">
    {% if section.settings.eyebrow != blank %}
      <p class="riift-eyebrow riift-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    <div class="riift-hero__copy">
      {% if slide_count == 0 %}
        <div class="riift-hero__copy-set is-active">
          {% if section.settings.fallback_title != blank %}
            <div class="riift-hero__headline">
              <span class="riift-hero__phrase riift-h1">{{ section.settings.fallback_title }}</span>
            </div>
          {% endif %}
          {% if section.settings.fallback_subtitle != blank %}
            <p class="riift-hero__subtitle">{{ section.settings.fallback_subtitle }}</p>
          {% endif %}
        </div>
      {% else %}
        {% assign copy_index = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'slide' %}
            <div class="riift-hero__copy-set{% if copy_index == 0 %} is-active{% endif %}" {{ block.shopify_attributes }}>
              {% if block.settings.eyebrow != blank %}
                <p class="riift-eyebrow riift-hero__slide-eyebrow">{{ block.settings.eyebrow }}</p>
              {% endif %}
              {% if block.settings.title != blank %}
                <div class="riift-hero__headline">
                  <span class="riift-hero__phrase riift-h1">{{ block.settings.title }}</span>
                </div>
              {% endif %}
              {% if block.settings.subtitle != blank %}
                <p class="riift-hero__subtitle">{{ block.settings.subtitle }}</p>
              {% endif %}
            </div>
            {% assign copy_index = copy_index | plus: 1 %}
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>

    {% if section.settings.show_button and section.settings.button_label != blank %}
      {% render 'riift-button',
        variant: 'pill',
        label: section.settings.button_label,
        url: section.settings.button_url,
        class: 'riift-hero__cta'
      %}
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "RIIFT Hero",
  "class": "riift-hero-section",
  "max_blocks": 5,
  "settings": [
    {
      "type": "select",
      "id": "height",
      "label": "Height",
      "options": [
        { "value": "viewport", "label": "Full viewport (home)" },
        { "value": "interior", "label": "Interior (fixed band)" }
      ],
      "default": "viewport"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "info": "Shown above all slides (optional)."
    },
    {
      "type": "text",
      "id": "fallback_title",
      "label": "Fallback title",
      "info": "Used only when no slide blocks are added.",
      "default": "Recess Integrated"
    },
    {
      "type": "text",
      "id": "fallback_subtitle",
      "label": "Fallback subtitle",
      "default": "No Drag. No Tools. No Compromise."
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Learn more",
      "visible_if": "{{ section.settings.show_button }}"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link",
      "visible_if": "{{ section.settings.show_button }}"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Timing"
    },
    {
      "type": "range",
      "id": "slide_interval",
      "label": "Slide interval (seconds)",
      "min": 2,
      "max": 16,
      "step": 1,
      "default": 3,
      "info": "Image, title, and subtitle crossfade together. Ignored when only one slide."
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "info": "Optional — overrides section eyebrow for this slide only."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Recess Integrated"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "No Drag. No Tools. No Compromise."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "RIIFT Hero",
      "settings": {
        "height": "viewport",
        "show_button": true,
        "slide_interval": 3
      },
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "title": "Recess Integrated",
            "subtitle": "No Drag. No Tools. No Compromise."
          }
        },
        {
          "type": "slide",
          "settings": {
            "title": "Perfectly Balanced",
            "subtitle": "Unpowered. Foil Assist. E-Foil. Adapts to your ride."
          }
        },
        {
          "type": "slide",
          "settings": {
            "title": "Pure Performance",
            "subtitle": "Your Shaper. Your Foil. Your Vision."
          }
        }
      ]
    },
    {
      "name": "RIIFT Page hero",
      "settings": {
        "height": "interior",
        "eyebrow": "RIIFT Enabled",
        "show_button": false,
        "alignment": "center",
        "slide_interval": 8
      },
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "title": "Page title",
            "subtitle": "Optional intro line for this page."
          }
        }
      ]
    }
  ]
}
{% endschema %}

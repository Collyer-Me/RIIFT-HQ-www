<div class="riift-band" data-section-id="{{ section.id }}">
  <div class="riift-band__inner">
  {% if section.settings.heading != blank %}
    <h2 class="riift-h2" style="margin-bottom: 32px;" data-reveal>{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="riift-split-band riift-split-band--{{ section.settings.ratio }}" data-reveal>
    <div class="riift-split-band__primary">
      {% if section.settings.left_heading != blank %}
        <h2 class="riift-h2" style="margin-bottom: 24px;">{{ section.settings.left_heading }}</h2>
      {% endif %}
      <div class="riift-split-band__content">
        {{ section.settings.left_content }}
      </div>
    </div>
    <div class="riift-split-band__secondary">
      {% if section.settings.right_heading != blank %}
        <h2 class="riift-h2" style="margin-bottom: 24px;">{{ section.settings.right_heading }}</h2>
      {% endif %}
      <div class="riift-split-band__content">
        {{ section.settings.right_content }}
      </div>
    </div>
  </div>
  </div>
</div>

{% schema %}
{
  "name": "RIIFT Split band",
  "class": "riift-split-band-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading (optional)"
    },
    {
      "type": "select",
      "id": "ratio",
      "label": "Column ratio",
      "options": [
        { "value": "balanced", "label": "Balanced (1:1)" },
        { "value": "form", "label": "Form layout (1.3:1)" }
      ],
      "default": "balanced"
    },
    {
      "type": "header",
      "content": "Primary column"
    },
    {
      "type": "text",
      "id": "left_heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "left_content",
      "label": "Content"
    },
    {
      "type": "header",
      "content": "Secondary column"
    },
    {
      "type": "text",
      "id": "right_heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "right_content",
      "label": "Content"
    }
  ],
  "presets": [
    {
      "name": "RIIFT Split band"
    }
  ]
}
{% endschema %}

{% liquid
  assign current_product = product
  if section.settings.product != blank
    assign current_product = section.settings.product
  endif

  assign selected_variant = current_product.selected_or_first_available_variant
  assign hero_image = selected_variant.featured_image | default: current_product.featured_image
  assign has_variant_picker = false

  unless current_product.has_only_default_variant
    for option in current_product.options_with_values
      if option.values.size > 1
        assign has_variant_picker = true
        break
      endif
    endfor
  endunless
%}

<div class="riift-page riift-product-standard-section" data-section-id="{{ section.id }}">
  <div class="riift-product-standard" data-riift-product-standard>
    <script type="application/json" data-riift-product-data>
      [{% for variant in current_product.variants %}{% render 'riift-standard-variant-json', variant: variant, product: current_product %}{% unless forloop.last %},{% endunless %}{% endfor %}]
    </script>

    <div class="riift-product-standard__grid">
      <div class="riift-product-standard__gallery">
        <div class="riift-product-standard__hero">
          {% if hero_image != blank %}
            {{
              hero_image
              | image_url: width: 1600
              | image_tag:
                class: 'riift-product-standard__hero-image',
                loading: 'eager',
                alt: current_product.title,
                data-product-hero-image: ''
            }}
          {% else %}
            <div class="riift-product-standard__hero-placeholder" data-product-hero-image></div>
          {% endif %}
        </div>

        {% if current_product.media.size > 1 %}
          <div class="riift-product-standard__thumbs" role="list" aria-label="Product gallery">
            {% for media in current_product.media limit: 6 %}
              <button
                type="button"
                class="riift-product-standard__thumb{% if forloop.first %} is-active{% endif %}"
                data-thumb-index="{{ forloop.index0 }}"
                aria-label="{{ media.alt | default: current_product.title | escape }}"
                role="listitem"
              >
                {% if media.media_type == 'image' %}
                  {{
                    media
                    | image_url: width: 200
                    | image_tag: loading: 'lazy', alt: media.alt | default: current_product.title
                  }}
                {% else %}
                  <span class="riift-product-standard__thumb-label">{{ media.alt | default: 'Media' }}</span>
                {% endif %}
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <div class="riift-product-standard__info">
        {% capture eyebrow %}
          {% render 'riift-product-mf', product: current_product, key: 'eyebrow' %}
        {% endcapture %}
        {% if eyebrow != blank %}
          <p class="riift-eyebrow riift-product-standard__eyebrow">{{ eyebrow | strip }}</p>
        {% endif %}

        <h1 class="riift-h1 riift-product-standard__title">{{ current_product.title }}</h1>

        <div class="riift-product-standard__price-row">
          <span class="riift-product-standard__price" data-product-price>{{ selected_variant.price | money }}</span>
          {% capture price_note %}
            {% render 'riift-product-mf', product: current_product, key: 'price_note' %}
          {% endcapture %}
          {% if price_note != blank %}
            <span class="riift-product-standard__price-note">{{ price_note | strip }}</span>
          {% endif %}
        </div>

        {% if current_product.description != blank %}
          <div class="riift-body riift-product-standard__description">{{ current_product.description }}</div>
        {% endif %}

        <form
          class="riift-product-standard__form"
          action="{{ routes.cart_add_url }}"
          method="post"
          data-product-form
        >
          <input type="hidden" name="id" value="{{ selected_variant.id }}" data-variant-input>
          <input type="hidden" name="quantity" value="1">

          {% if has_variant_picker %}
            {% for option in current_product.options_with_values %}
              {% if option.values.size > 1 %}
                <fieldset class="riift-product-standard__option" data-option-index="{{ option.position | minus: 1 }}">
                  <legend class="riift-product-standard__option-label">{{ option.name }}</legend>
                  <div class="riift-product-standard__option-values" role="group" aria-label="{{ option.name }}">
                    {% for value in option.values %}
                      {% liquid
                        assign is_selected = false
                        if option.position == 1 and selected_variant.option1 == value
                          assign is_selected = true
                        elsif option.position == 2 and selected_variant.option2 == value
                          assign is_selected = true
                        elsif option.position == 3 and selected_variant.option3 == value
                          assign is_selected = true
                        endif
                        assign option_index = option.position | minus: 1
                      %}
                      <button
                        type="button"
                        class="riift-product-standard__option-btn{% if is_selected %} is-selected{% endif %}"
                        data-option-button
                        data-option-index="{{ option_index }}"
                        data-option-value="{{ value | escape }}"
                        aria-pressed="{% if is_selected %}true{% else %}false{% endif %}"
                      >
                        {{ value }}
                      </button>
                    {% endfor %}
                  </div>
                </fieldset>
              {% endif %}
            {% endfor %}
          {% endif %}

          <div class="riift-product-standard__actions">
            <button
              type="submit"
              class="riift-btn riift-btn--solid riift-btn--solid-pill"
              data-add-to-cart
              {% unless selected_variant.available %}disabled{% endunless %}
            >
              {% if selected_variant.available %}
                Add to cart
              {% else %}
                {{ 'products.product.sold_out' | t }}
              {% endif %}
            </button>
          </div>
          <p class="riift-caption riift-product-standard__error" data-product-error hidden></p>
        </form>

        {% capture footnote %}
          {% render 'riift-product-mf', product: current_product, key: 'footnote' %}
        {% endcapture %}
        {% if footnote != blank %}
          <p class="riift-caption riift-product-standard__footnote">{{ footnote | strip }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<script src="{{ 'riift-product-standard.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "RIIFT Product standard",
  "class": "riift-product-standard-section",
  "tag": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Leave blank to use the current product page. Content from product fields and riift metafields."
    }
  ],
  "presets": [
    {
      "name": "RIIFT Product standard"
    }
  ]
}
{% endschema %}

<div class="riift-band{% if section.settings.band_style == 'off-white' %} riift-band--off-white{% elsif section.settings.band_style == 'dark' %} riift-band--dark{% endif %}" data-section-id="{{ section.id }}">
  <div class="riift-band__inner riift-text-band riift-text-band--center" data-reveal>
    {% if section.settings.heading != blank %}
      <h2 class="riift-h2">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.body != blank %}
      <p class="riift-body" style="margin-top: 16px; max-width: 48ch; margin-left: auto; margin-right: auto;">{{ section.settings.body }}</p>
    {% endif %}
    <div style="margin-top: 28px; display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;">
      {% if section.settings.open_modal %}
        <button type="button" class="riift-btn riift-btn--solid" data-riift-wizard-open="riift-wizard-modal">
          {{ section.settings.button_label }}
        </button>
      {% else %}
        <a href="{{ section.settings.button_url | default: '/pages/wizard' }}" class="riift-btn riift-btn--solid">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
      {% if section.settings.secondary_label != blank %}
        <a href="{{ section.settings.secondary_url | default: '/pages/wizard' }}" class="riift-btn riift-btn--pill">
          {{ section.settings.secondary_label }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "RIIFT Wizard launcher",
  "class": "riift-wizard-launcher-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Not sure where to start?"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Answer a few questions and watch the right RIIFT Tracks and Battery Kit rise to the top."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary button label",
      "default": "Find your setup"
    },
    {
      "type": "checkbox",
      "id": "open_modal",
      "label": "Open wizard in modal (homepage)",
      "default": true
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Primary button link",
      "info": "Used when modal is off"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label"
    },
    {
      "type": "url",
      "id": "secondary_url",
      "label": "Secondary button link"
    },
    {
      "type": "select",
      "id": "band_style",
      "label": "Band style",
      "options": [
        { "value": "none", "label": "White" },
        { "value": "off-white", "label": "Off-white" },
        { "value": "dark", "label": "Dark" }
      ],
      "default": "off-white"
    }
  ],
  "presets": [
    {
      "name": "RIIFT Wizard launcher"
    }
  ]
}
{% endschema %}

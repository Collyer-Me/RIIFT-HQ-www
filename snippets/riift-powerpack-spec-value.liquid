{% doc %}
  Resolves a variant spec from riift metafields only (no theme fallbacks).

  @param {variant} variant
  @param {string} key
{% enddoc %}

{% liquid
  case key
    when 'tier_label'
      echo variant.metafields.riift.tier_label.value
    when 'usable_energy'
      echo variant.metafields.riift.usable_energy.value
    when 'efoil_run_time'
      echo variant.metafields.riift.efoil_run_time.value
    when 'pack_weight'
      echo variant.metafields.riift.pack_weight.value
    when 'track_compat_line'
      echo variant.metafields.riift.track_compat_line.value
    when 'track_compat_table'
      echo variant.metafields.riift.track_compat_table.value
    when 'battery_config'
      echo variant.metafields.riift.battery_config.value
    when 'cell'
      echo variant.metafields.riift.cell.value
    when 'nominal_voltage'
      echo variant.metafields.riift.nominal_voltage.value
    when 'capacity'
      echo variant.metafields.riift.capacity.value
    when 'peak_thrust'
      echo variant.metafields.riift.peak_thrust.value
    when 'battery_weight'
      echo variant.metafields.riift.battery_weight.value
    when 'system_weight'
      echo variant.metafields.riift.system_weight.value
    when 'recharge_time'
      echo variant.metafields.riift.recharge_time.value
  endcase
%}
